<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>KaelKodes.KaelsKleave</AssemblyName>
    <RootNamespace>KaelKodes.KaelsKleave</RootNamespace>
    <Version>1.0.0</Version>
    <PackageId>KaelKodes.KaelsKleave</PackageId>
    <Authors>Kael Kodes</Authors>
    <Description>Range-based melee cleave for Unturned zombies.</Description>
    <PackageTags>openmod-plugin unturned-plugin</PackageTags>
    <OpenModPlugin>true</OpenModPlugin>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenMod.Unturned" Version="3.8.10" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="config.yaml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
